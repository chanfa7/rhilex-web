{
  "name": "rhilex-web",
  "version": "0.7.4",
  "private": true,
  "description": "RHILEX - 做专业的边缘数据处理引擎",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 8000",
    "lint": "eslint --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src",
    "lint:fix": "eslint --fix --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src",
    "lint:prettier": "prettier -c --write \"**/**.{js,jsx,tsx,ts,less,md,json}\" --end-of-line auto",
    "tsc": "tsc --noEmit",
    "prepare": "husky install"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": "eslint --ext .js,.jsx,.ts,.tsx",
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ],
  "dependencies": {
    "@ant-design/icons": "^5.0.1",
    "@ant-design/plots": "^2.2.2",
    "@ant-design/pro-components": "^2.8.10",
    "@codemirror/autocomplete": "^6.10.2",
    "@codemirror/language": "^6.10.5",
    "@codemirror/lint": "^6.4.2",
    "@uiw/codemirror-extensions-langs": "^4.21.20",
    "@uiw/codemirror-theme-darcula": "^4.21.20",
    "@uiw/codemirror-theme-github": "^4.23.6",
    "@uiw/react-codemirror": "^4.21.20",
    "@xterm/addon-fit": "^0.9.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.4.0",
    "ahooks": "^3.7.8",
    "antd": "^5.29.3",
    "axios": "^1.9.0",
    "clsx": "^1.2.1",
    "jsencrypt": "^3.3.2",
    "luaparse": "^0.3.1",
    "mac-scrollbar": "^0.13.6",
    "nanoid": "^5.0.7",
    "react": "^18.2.0",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-intl": "^7.1.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^1.13.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/luaparse": "^0.2.11",
    "@types/node": "^25.5.2",
    "@types/react": "^18.0.0",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "husky": "^7.0.4",
    "less": "^4.4.0",
    "lint-staged": "^10.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.0",
    "vite-plugin-svgr": "^4.3.0"
  },
  "resolutions": {
    "@types/react": "^18.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
